# =============================================================================
# Vigmis environment variables
# Copy to .env.local (dev) / set in Railway (API) + Vercel (web).
# SECURITY: every value marked (SECRET) must be a strong, unique, random value
# and must NEVER be committed. Rotate immediately if leaked.
# =============================================================================

# App
APP_ENV=local
WEB_URL=http://localhost:3000          # MUST be the real https origin in prod (CORS + redirects)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # public — ships to the browser. RLS must be ON for every table (migration 045).
SUPABASE_SERVICE_ROLE_KEY=             # (SECRET) the API runs as this. Bypasses RLS. Server-only, never NEXT_PUBLIC.

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=                      # (SECRET)

# Token encryption — REQUIRED. AES-256-GCM key for OAuth tokens at rest.
# Generate: `openssl rand -hex 32`  (must be exactly 64 hex chars / 32 bytes)
TOKEN_ENCRYPTION_KEY=                  # (SECRET) the API throws on startup of token flows if unset/invalid

# AI providers
OPENAI_API_KEY=                        # (SECRET)
ANTHROPIC_API_KEY=                     # (SECRET) — Claude routing
GEMINI_API_KEY=                        # (SECRET) — optional

# Google Ads (when approved)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=              # (SECRET)
GOOGLE_ADS_DEVELOPER_TOKEN=            # (SECRET)
GOOGLE_ADS_ENABLED=false

# Meta Ads (when approved)
META_APP_ID=
META_APP_SECRET=                       # (SECRET)
META_ADS_ENABLED=false

# TikTok Ads (OAuth activates only when all three are set)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=                  # (SECRET)
TIKTOK_REDIRECT_URI=

# Shopify (Partner App — product/inventory sync + order webhooks)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=                    # (SECRET) — also verifies inbound Shopify webhook HMACs
SHOPIFY_REDIRECT_URI=

# Billing — Stripe (migrated from Paddle 2026-06-08)
STRIPE_SECRET_KEY=                     # (SECRET) sk_live_... in production, sk_test_... in dev
STRIPE_WEBHOOK_SECRET=                 # (SECRET) whsec_... from Stripe webhook endpoint settings — REQUIRED
STRIPE_PRO_PRICE_ID=                   # Stripe Price ID for Scale plan ($49/month recurring)

# Billing — Paddle (DEPRECATED — replaced by Stripe)
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=

# News monitoring — https://newsapi.org (free tier OK for dev)
NEWSAPI_KEY=                           # (SECRET)

# Weather — https://openweathermap.org/api (free tier OK for dev)
OPENWEATHER_API_KEY=                   # (SECRET)

# Compliance / ops
ADMIN_SECRET=                          # (SECRET) gates /admin/* (freeze). Unset ⇒ /admin locked. Use `openssl rand -hex 24`.
OPS_ALERT_EMAIL=                       # receives stop-loss + crisis + downtime alerts
INSTATUS_WEBHOOK_SECRET=               # (SECRET) REQUIRED to accept /webhooks/instatus (fails closed if unset)

# Cron protection — REQUIRED.
# All /cron, /digest, /run-all, /invoice, /refresh-all, /snapshot endpoints reject
# requests whose `x-cron-secret` header != CRON_SECRET. There is NO default anymore:
# if this is unset, ALL cron endpoints return 401. Generate: `openssl rand -hex 24`.
# The scheduler that triggers the crons MUST send the same value.
CRON_SECRET=                           # (SECRET)

# Twilio (WhatsApp briefings)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=                     # (SECRET)
TWILIO_WHATSAPP_FROM=

# SendGrid (Email briefings)
SENDGRID_API_KEY=                      # (SECRET)
